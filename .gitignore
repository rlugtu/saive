# Parent repo — each app (web/, mobile/) has its own .gitignore for build artifacts.

# OS / editor
.DS_Store
*.pem

# Build artifacts (each app also ignores its own; this covers stray root output)
.next/
node_modules/

# Logs
*-debug.log*

# Local release-readiness scratch (not committed)
APP_STORE_READINESS.md

# Env (each app opts in via its own .env.example)
.env
.env.*
!.env.example

.marketing