# Base URL of the web app (better-auth server + tRPC API).
# iOS Simulator: use localhost (it shares the Mac's network — most reliable).
# Physical device: use the Mac's LAN IP (e.g. http://192.168.1.152:3000) with
#   the phone on the same Wi-Fi. EXPO_PUBLIC_* is inlined at bundle time, so
#   after changing this, restart Metro with cache clear:  npx expo start -c
EXPO_PUBLIC_API_URL=http://localhost:3000

# Mapbox tokens for the Near me map (@rnmapbox/maps). Two distinct tokens:
#   - MAPBOX_DOWNLOAD_TOKEN: a SECRET token (sk.…) with the DOWNLOADS:READ scope,
#     used only at prebuild/build time to fetch the native SDK. Injected via
#     app.config.js; never shipped in the binary.
#   - EXPO_PUBLIC_MAPBOX_TOKEN: a PUBLIC token (pk.…) inlined into the JS bundle
#     and passed to Mapbox.setAccessToken() at runtime to load map tiles.
MAPBOX_DOWNLOAD_TOKEN=
EXPO_PUBLIC_MAPBOX_TOKEN=

# Supabase Realtime — near-real-time direct-message delivery. Both OPTIONAL: if unset, DMs
# fall back to polling. Public anon key + project URL (same Supabase project as the web app).
# EXPO_PUBLIC_* is inlined at bundle time, so restart Metro with -c after changing.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
