# --- Supabase Postgres ---
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma for migrations.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase Realtime (direct-message delivery) ---
# Used to broadcast a tiny content-free "new activity" ping so clients refetch DMs in
# near-real-time. All four are OPTIONAL — if unset, DMs still work via polling. Values come
# from the Supabase project's API settings (Project URL + anon/public key).
#   Server (broadcasts the ping):
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
#   Browser client (subscribes) — must be NEXT_PUBLIC_ to reach the bundle:
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- better-auth ---
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Dev = http://localhost:3000. In production this MUST be the exact public origin the clients call,
# including the mobile app's EXPO_PUBLIC_API_URL (https://klect.vercel.app). It sets the Google OAuth
# redirect_uri; if it points at a different domain, mobile Google login completes but loads the web
# app instead of returning to the native app via the klect:// deep link.
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth (from Google Cloud Console) ---
# Authorized redirect URIs must include <BETTER_AUTH_URL>/api/auth/callback/google for EVERY deployed
# origin (e.g. https://klect.vercel.app/api/auth/callback/google), or Google returns redirect_uri_mismatch.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Mapbox (location autocomplete via Search Box API; token from mapbox.com) ---
# Server-side only — never prefix with NEXT_PUBLIC_. A public pk.* token works. Feature
# degrades to plain text if unset.
MAPBOX_TOKEN=""

# --- LinkPreview (link autofill extraction; API key from linkpreview.net) ---
# Primary generic unfurler for pasted links. Server-side only. If unset, autofill
# falls back to Microlink (free, IP-rate-limited).
LINKPREVIEW_API_KEY=""

# --- Social-media link enrichment (Instagram / TikTok / Facebook) ---
# Scraping API that returns the real caption + media for social-video links (e.g.
# ScrapeCreators / EnsembleData). Server-side only. If unset, social links fall back
# to the generic Microlink unfurl.
SOCIAL_SCRAPER_TOKEN=""
# Anthropic API key — comprehension layer (claude-haiku-4-5). Turns scraped social
# captions AND raw link metadata into clean title/location/description/tags. If unset,
# the raw caption / raw page metadata is used as-is (autofill still works).
ANTHROPIC_API_KEY=""

# --- Expo push notifications (mobile lockscreen alerts + app-icon badge) ---
# OPTIONAL. When set (create at expo.dev → Account → Access Tokens), the server includes it
# when sending Expo pushes so a leaked server can't impersonate you. Push still works if unset.
# Delivery no-ops entirely when no devices are registered, so leaving this blank is fine for web/CI.
EXPO_ACCESS_TOKEN=""
