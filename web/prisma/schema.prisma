// Klect schema — see DESIGN.md §3 for the model overview.
// Auth tables (Session/Account/Verification) and better-auth wiring are added in Step 2.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  COLLABORATOR
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

enum Theme {
  PIXEL_LIGHT
  PIXEL_DARK
  MODERN_LIGHT
  MODERN_DARK
  JOURNAL_LIGHT
  JOURNAL_DARK
}

// Core user. Fields `name`, `email`, `emailVerified`, `image` are the better-auth
// defaults; the rest are our app profile fields (collected at onboarding).
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  handle        String?   @unique // public @handle; required via onboarding gate
  firstName     String?
  lastName      String?
  birthday      DateTime?
  icon          String? // emoji
  theme         Theme     @default(MODERN_LIGHT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // better-auth relations
  sessions Session[]
  accounts Account[]

  // app relations
  ownedLists  List[]           @relation("ListOwner")
  memberships ListMembership[]
  invitesSent ListInvite[]     @relation("InviteSender")
  tags        Tag[]
  comments    Comment[]
  polls       Poll[]           @relation("PollCreator")
  pollVotes   PollVote[]

  friendRequestsSent     Friendship[] @relation("FriendRequester")
  friendRequestsReceived Friendship[] @relation("FriendAddressee")

  conversations ConversationParticipant[] @relation("UserConversations")
  messagesSent  Message[]                 @relation("MessagesSent")

  listChatSent ListChatMessage[] @relation("ListChatSent")

  // Push notifications (mobile): one row per device + per-user category prefs.
  deviceTokens           DeviceToken[]
  notificationPreference NotificationPreference?
}

// A friendship between two users. Directed request (requester -> addressee) that
// becomes mutual once accepted. "My friends" = ACCEPTED rows where I'm either side.
model Friendship {
  id          String       @id @default(uuid())
  requesterId String
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

// ---- Direct messaging (see DESIGN.md) ----
// A 1:1 private thread. Independent of Friendship (no cascade on unfriend) so history
// survives; sending is gated on a live friendship at write time. `pairKey` is the two
// participant ids sorted + joined — its unique constraint makes get-or-create atomic.
model Conversation {
  id            String   @id @default(uuid())
  pairKey       String   @unique
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

// Per-user state on a conversation (mirrors the ListMembership participant-row pattern).
// `clearedAt`: messages at/before it are hidden from this user (drives clear + delete;
// thread reappears on newer activity). `lastReadAt`: unread = the other user's messages
// newer than this (and newer than clearedAt).
model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  clearedAt      DateTime?
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ---- better-auth managed models (generated via @better-auth/cli) ----

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // hashed; email/password credential lives here, not on User
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model List {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  icon        String   @default("📁") // emoji
  isPublic    Boolean  @default(false) // private by default; public = read-only viewable by anyone
  ownerId     String
  owner       User     @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships  ListMembership[]
  invites      ListInvite[]
  bookmarks    Bookmark[]
  comments     Comment[]
  polls        Poll[]
  chatMessages ListChatMessage[]

  @@index([ownerId])
}

// Join of user <-> list carrying the role and this user's personal ordering.
model ListMembership {
  id        String   @id @default(uuid())
  listId    String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  position  Int      @default(0) // per-user home-page order
  createdAt DateTime @default(now())

  // Chatroom read state: unread = messages from others newer than this. Mirrors
  // ConversationParticipant.lastReadAt but for the per-list group chat.
  chatLastReadAt DateTime?

  @@unique([listId, userId])
  @@index([userId])
}

// ---- List chatrooms (see DESIGN.md) ----
// A message in a list's group chat, shared by all the list's members. Mirrors `Message`
// but list-scoped (the chatroom is the list; membership is the ConversationParticipant
// analogue). Owner-only clear hard-deletes rows. `(listId, createdAt)` index keeps every
// keyset-paginated page a cheap indexed read regardless of history length.
model ListChatMessage {
  id        String   @id @default(uuid())
  listId    String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("ListChatSent", fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([listId, createdAt])
}

// Pending/accepted invitation, keyed by email so we can invite non-users.
model ListInvite {
  id          String       @id @default(uuid())
  listId      String
  list        List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  email       String
  role        Role
  token       String       @unique @default(uuid())
  status      InviteStatus @default(PENDING)
  invitedById String
  invitedBy   User         @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([listId, email])
  @@index([email])
}

// ---- Push notifications (mobile) ----
// One row per registered device. `token` is the Expo push token
// (ExponentPushToken[...]); its unique constraint lets register upsert idempotently
// and reassign a device that signs into a different account. Best-effort: rows with
// tokens that come back DeviceNotRegistered are pruned on send (see core/push.ts).
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Per-user push category toggles. Absent row = everything on (defaults below); a row
// is created lazily the first time the user changes a toggle (see core/notifications.ts).
model NotificationPreference {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  directMessages Boolean  @default(true)
  listChat       Boolean  @default(true)
  friends        Boolean  @default(true)
  lists          Boolean  @default(true)
  comments       Boolean  @default(true)
  polls          Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

// Marketing waitlist / beta early-access signups from the logged-out landing page.
// Not tied to a User — just captures interest to review later.
model WaitlistSignup {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Bookmark {
  id          String   @id @default(uuid())
  listId      String
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  urls        String[] // first entry is the primary "open" / original source link
  images      String[] @default([]) // extracted photo URLs (remote)
  notes       String   @default("")
  location    String   @default("")
  latitude    Float? // set when location is picked from autocomplete; null for free text / old rows
  longitude   Float?
  rating      Int      @default(0) // 0–5
  visited     Boolean  @default(false)
  videoUrl    String   @default("") // detected playable video (embed src or media file)
  videoType   String   @default("") // "" | "iframe" | "file"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        BookmarkTag[]
  comments    Comment[]
  pollOptions PollOption[]

  @@index([listId])
}

// User-scoped tag; shared across all of the user's lists.
model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("") // hex color assigned at creation; "" = none (legacy)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  bookmarks BookmarkTag[]

  @@unique([userId, name])
  @@index([userId])
}

model BookmarkTag {
  bookmarkId String
  bookmark   Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, tagId])
  @@index([tagId])
}

// Comment on EITHER a bookmark OR a list — exactly one of bookmarkId/listId is set.
// (Enforced in app logic + a DB check constraint added with the migration.)
model Comment {
  id         String    @id @default(uuid())
  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  value      String
  createdAt  DateTime  @default(now())
  bookmarkId String?
  bookmark   Bookmark? @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  listId     String?
  list       List?     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([bookmarkId])
  @@index([listId])
  @@index([authorId])
}

// A poll inside a list. Options are bookmarks from the same list (PollOption);
// members vote on them (PollVote). `creatorId` drives the "collaborator edits
// only their own poll; owner edits any" rule (see core/polls.ts).
model Poll {
  id             String   @id @default(uuid())
  listId         String
  list           List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  creatorId      String
  creator        User     @relation("PollCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  name           String
  description    String   @default("")
  startAt        DateTime @default(now())
  endAt          DateTime? // null = no end (open indefinitely)
  maxVotes       Int? // votes per participant; null = unlimited
  revotesAllowed Boolean  @default(false)
  isAnonymous    Boolean  @default(false) // set only at creation; hides who voted for what
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  options PollOption[]
  votes   PollVote[]

  @@index([listId])
  @@index([creatorId])
}

// A bookmark offered as a choice in a poll. Deleting the bookmark (or the poll)
// cascades this row away, which cascades its votes — so removing an option or
// deleting a bookmark auto-frees each voter's spent vote (refund is derived).
model PollOption {
  id         String   @id @default(uuid())
  pollId     String
  poll       Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  bookmarkId String
  bookmark   Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  votes PollVote[]

  @@unique([pollId, bookmarkId]) // a bookmark appears at most once per poll
  @@index([pollId])
  @@index([bookmarkId])
}

// One user's vote for one option. Unweighted: at most one vote per option per
// user. `pollId` is denormalized for cheap per-poll tallies/refund counts.
model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([optionId, userId])
  @@index([pollId])
  @@index([userId])
}
